# ── Google Gemini ──────────────────────────────────────────────────────────────
GOOGLE_API_KEY="your-google-gemini-api-key-here"

# ── LLM Model ──────────────────────────────────────────────────────────────────
LLM_MODEL="gemini-2.5-flash"

# ── RAG Collection (used by rag_agent / rag_search) ────────────────────────────
QDRANT_URL="https://your-rag-cluster-id.region.cloud.qdrant.io"
QDRANT_API_KEY="your-rag-qdrant-api-key-here"
COLLECTION_NAME="your-rag-collection-name"

# ── Exam Collection (used by exam_agent / exam_generator) ──────────────────────
# If the exam corpus lives in a different Qdrant cluster, set these.
# Leave empty to fall back to the RAG collection above.
EXAM_QDRANT_URL="https://your-exam-cluster-id.region.cloud.qdrant.io"
EXAM_QDRANT_API_KEY="your-exam-qdrant-api-key-here"
EXAM_COLLECTION_NAME="your-exam-collection-name"

# ── Embedding Model ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# ── RAG Settings ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# ── Exam Settings ───────────────────────────────────────────────────────────────
DEFAULT_N_QUESTIONS=5

# ── Optional: Tavily for course search (grade_exam provides mock results without it) ──
TAVILY_API_KEY=""

# ── App ─────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
